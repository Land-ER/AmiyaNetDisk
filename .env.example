# AmiyaNetDisk 环境变量配置
# 复制此文件为 .env 并修改配置

SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///app.db

# SMTP 邮件服务器配置
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# Root 管理员账号
ROOT_EMAIL=root@example.com
ROOT_PASSWORD=root123456

# 上传文件大小限制（字节，默认 100MB）
MAX_CONTENT_LENGTH=104857600

# Embedding 语义搜索（默认关闭；开启前需安装 sentence-transformers）
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_TOP_K=50

# 校园网注册验证（默认关闭）
CAMPUS_VERIFY_ENABLED=false
CAMPUS_VERIFY_MIN_SUCCESS=1
CAMPUS_VERIFY_TTL_SECONDS=600
CAMPUS_VERIFY_ALLOWED_HOST=zb.hit.edu.cn
